--- !u!114 &1395499325
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1395499324}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 29e1bdd96aceea6468e7850994a57248, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  backgroundImage: {fileID: 333690179}
  fadeImage: {fileID: 1118705454}
  storyText: {fileID: 700725792}
  frames:
  - background: {fileID: 21300000, guid: 14d70868c2df0fa40874b4fe8bcf07f1, type: 3}
    texts:
    - "\u5404\u4F4D\uFF0C\u6B61\u8FCE\u52A0\u5165\u300C\u6316\u52D2\u5FB5\u4FE1\u793E\u300D\u3002\r\n\u4F60\u73FE\u5728\u662F\u525B\u4E0A\u7DDA\u7684\u83DC\u9CE5\u8ABF\u67E5\u54E1\uFF0C\u771F\u7684\u8D85\u83DC\u3002\r\n\u6628\u5929\u624D\u9762\u8A66\uFF0C\u4ECA\u5929\u5C31\u88AB\u53EB\u4F86\u8DD1\u5927\u6848\u5B50\uFF0C\u6C92\u932F\uFF0C\u5C31\u662F\u9019\u9EBC\u8D95\u3002\r\n"
  - background: {fileID: 21300000, guid: 8882ad94246870c448414990e50792d7, type: 3}
    texts:
    - "\u59D4\u8A17\u4EBA\u53EB \u6797\u627F\u6D69\uFF0C\u505A\u5EE3\u544A\u7684\u5C0E\u6F14\uFF0C\u6EFF\u6709\u540D\u3002\u4E09\u5E74\u524D\u8DDF\u5973\u660E\u661F
      \u5B89\u742A \u7D50\u5A5A\uFF0C\u5A5A\u5F8C\u5B89\u742A\u5C31\u9000\u5708\uFF0C\u5F62\u8C61\u770B\u8D77\u4F86\u751C\u751C\u7684\uFF0C\u6A19\u6E96\u6A21\u7BC4\u592B\u59BB\u3002"
  - background: {fileID: 21300000, guid: 1648f912a6554374c9f4fbb839c936fd, type: 3}
    texts:
    - "\u7D50\u679C\u6700\u8FD1\u602A\u5F97\u5F88\u3002\u6797\u5C0E\u8AAA\u5B89\u742A\u9019\u9663\u5B50\u6709\u5E7E\u4EF6\u4E8B\u5F88\u4E0D\u5C0D\uFF1A\n1.\u4E00\u76F4\u903C\u4ED6\u5403\u4E00\u4E9B\u4F86\u8DEF\u4E0D\u660E\u7684\u4FDD\u5065\u54C1\uFF0C\u4E0D\u5403\u9084\u6703\u751F\u6C23\u3002\r\n\r2.\u4E09\u4E0D\u4E94\u6642\u8DDF\u95A8\u871C\u51FA\u9580\uFF0C\u884C\u7A0B\u90FD\u8B1B\u4E0D\u6E05\u695A\u3002"
    - "\r3.\u6700\u626F\u7684\u662F\u2026\u2026\u5979\u9577\u671F\u79DF\u4E86 709
      \u865F\u623F\u3002\r\n \u4EBA\u6C92\u4F4F\u4E5F\u4E0D\u8B93\u5225\u4EBA\u9032\uFF0C\u770B\u8D77\u4F86\u5C31\u662F\u6709\u9B3C\u3002"
  - background: {fileID: 21300000, guid: 69b151a0740d9a44c9be017aabfcbc10, type: 3}
    texts:
    - "\u56E0\u70BA\u5A5A\u524D\u5354\u8B70\u5BEB\u6B7B\u300C\u4E0D\u80FD\u61F7\u7591\u5F7C\u6B64\u300D\uFF0C\u6797\u5C0E\u4E5F\u4E0D\u6562\u7576\u9762\u554F\uFF0C\u53EA\u597D\u5077\u5077\u627E\u6211\u5011\u8ABF\u67E5\u3002"
  - background: {fileID: 21300000, guid: d93554638f1dba646a63e3885f4a0655, type: 3}
    texts:
    - "\u4ECA\u5929\u662F 2082 \u5E74 2 \u6708 15 \u65E5\uFF0C\u60C5\u4EBA\u7BC0\u9694\u4E00\u5929\u3002\u6797\u5C0E\u8D81\u8457\u5E36\u5B89\u742A\u51FA\u53BB\u5403\u98EF\uFF0C\u4F60\u5011\u5C31\u6709\u4E00\u9813\u98EF\u7684\u6642\u9593\u67E5\u67E5
      709 \u5230\u5E95\u5728\u641E\u4EC0\u9EBC\u3002"
  - background: {fileID: 21300000, guid: 9702432f6cbecf34e9616231136875e9, type: 3}
    texts:
    - "\u4EFB\u52D9\u5F88\u55AE\u7D14\uFF1A\r\n\u627E\u5230\u8B49\u64DA \u2192 \u5728\u5B89\u742A\u56DE\u4F86\u524D\u96E2\u958B
      \u2192 \u4E0D\u8981\u88AB\u4EFB\u4F55\u4EBA\u767C\u73FE\u3002\u505A\u5230\u7684\u8A71\uFF0C\u5C31\u80FD\u62FF\u5230
      300 \u842C\u3002"
    - "\u73FE\u5728\u4F60\u5011\u5C31\u5728 709 \u865F\u623F\u88E1\u3002\u6240\u6709\u7DDA\u7D22\u90FD\u85CF\u5728\u9019\u500B\u7A7A\u9593\u3002\u6C92\u4EBA\u6703\u7D66\u63D0\u793A\u3001\u4E5F\u6C92\u6709\u5F8C\u63F4\uFF0C\u8A72\u7FFB\u7684\u7FFB\u3001\u8A72\u770B\u7684\u770B\uFF0C\u8B49\u64DA\u81EA\u5DF1\u627E\uFF0C\u6545\u4E8B\u81EA\u5DF1\u62FC\u3002"
    - "\u5C31\u9019\u6A23\uFF0C\u65B0\u624B\u7B2C\u4E00\u5929\u7684\u5DE5\u4F5C\u5167\u5BB9\u5927\u6982\u5C31\u662F\u5982\u6B64\u3002\u4E09\u767E\u842C\u5C31\u5728\u773C\u524D\uFF0C\u770B\u4F60\u5011\u80FD\u4E0D\u80FD\u62FF\u5F97\u5230\u3002"
  fadeSpeed: 1.5
  typingSpeed: 0.04
  text: {fileID: 2016545567}
  Rule: {fileID: 88644827}
